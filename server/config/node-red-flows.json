[
    {
        "id": "sf-flow-main",
        "type": "tab",
        "label": "SmartFarm DakLak - Soil Data",
        "disabled": false,
        "info": "Main data pipeline: MQTT → Decode → InfluxDB → Dashboard"
    },
    {
        "id": "mqtt-in-chirpstack",
        "type": "mqtt in",
        "z": "sf-flow-main",
        "name": "ChirpStack MQTT",
        "topic": "application/#",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 130,
        "y": 200,
        "wires": [["decode-soil"]]
    },
    {
        "id": "decode-soil",
        "type": "function",
        "z": "sf-flow-main",
        "name": "Decode Soil Sensor",
        "func": "// Decode ChirpStack payload for soil multi-parameter sensor\n// Registers: Temp, Moisture, EC, Salinity, N, P, K, pH\n\ntry {\n    let payload = msg.payload;\n    \n    // Get raw data from ChirpStack\n    let data = payload.object || payload;\n    let devEUI = payload.devInfo?.devEUI || payload.devEUI || 'unknown';\n    let timestamp = payload.time || new Date().toISOString();\n    \n    // If data is base64 encoded, decode it\n    let rawData = data;\n    if (typeof data.data === 'string') {\n        // base64 decoded by codec\n        rawData = data;\n    }\n    \n    // Build sensor reading\n    let reading = {\n        device: devEUI,\n        timestamp: timestamp,\n        temperature: parseFloat(rawData.temperature) || 0,\n        moisture: parseFloat(rawData.moisture || rawData.humidity) || 0,\n        ec: parseInt(rawData.ec || rawData.ecValue) || 0,\n        salinity: parseInt(rawData.salinity) || 0,\n        nitrogen: parseInt(rawData.nitrogen || rawData.n) || 0,\n        phosphorus: parseInt(rawData.phosphorus || rawData.p) || 0,\n        potassium: parseInt(rawData.potassium || rawData.k) || 0,\n        ph: parseFloat(rawData.ph || rawData.pH) || 0\n    };\n    \n    msg.payload = reading;\n    return [msg, null];\n    \n} catch (e) {\n    node.error('Decode error: ' + e.message, msg);\n    return [null, msg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 200,
        "wires": [["influxdb-write", "debug-output"], ["error-log"]]
    },
    {
        "id": "influxdb-write",
        "type": "influxdb out",
        "z": "sf-flow-main",
        "influxdb": "influxdb-conn",
        "name": "Write to InfluxDB",
        "measurement": "soil",
        "precision": "",
        "retentionPolicy": "",
        "database": "",
        "precisionV18FluxV20": "ms",
        "retentionPolicyV18Flux": "",
        "x": 650,
        "y": 180,
        "wires": []
    },
    {
        "id": "debug-output",
        "type": "debug",
        "z": "sf-flow-main",
        "name": "Sensor Data",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload",
        "statusType": "msg",
        "x": 640,
        "y": 240,
        "wires": []
    },
    {
        "id": "error-log",
        "type": "debug",
        "z": "sf-flow-main",
        "name": "Decode Errors",
        "active": true,
        "tosidebar": true,
        "console": true,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "x": 630,
        "y": 300,
        "wires": []
    },
    {
        "id": "mqtt-broker",
        "type": "mqtt-broker",
        "name": "SmartFarm MQTT",
